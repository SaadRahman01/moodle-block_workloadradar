{{!
    @template block_workloadradar/radar_compact

    Compact gamified radar shown inside the dashboard block:
      [mode badge]  [7-day heatmap strip]  [top 3 imminent items]  [view full]
}}
<div class="wlradar wlradar--compact wlradar--mode-{{mode.key}}" data-region="radar-root">

    <header class="wlradar__mode" aria-label="{{mode.label}}">
        <span class="wlradar__mode-emoji" aria-hidden="true">{{mode.emoji}}</span>
        <span class="wlradar__mode-text">
            <strong class="wlradar__mode-label">{{mode.label}}</strong>
            <span class="wlradar__mode-sub">{{mode.sub}}</span>
        </span>
    </header>

    <div class="wlradar__strip" role="img" aria-label="{{#str}} heatmap_alt, block_workloadradar {{/str}}">
        {{#heatmap}}
            <div class="wlradar__cell wlradar__cell--i{{intensity}}
                        {{#collision}}wlradar__cell--collision{{/collision}}
                        {{#istoday}}wlradar__cell--today{{/istoday}}
                        {{#isweekend}}wlradar__cell--weekend{{/isweekend}}"
                 title="{{datestr}}: {{count}}"
                 data-count="{{count}}">
                <span class="wlradar__cell-day">{{daylabel}}</span>
                <span class="wlradar__cell-num">{{daynum}}</span>
                {{#count}}<span class="wlradar__cell-dot" aria-hidden="true">{{count}}</span>{{/count}}
            </div>
        {{/heatmap}}
    </div>

    {{^hasitems}}
        <p class="wlradar__empty">
            <span aria-hidden="true">🌿</span>
            {{#str}} empty_easymode, block_workloadradar {{/str}}
        </p>
    {{/hasitems}}

    {{#hasitems}}
        <ul class="wlradar__list">
            {{#topitems}}
                <li class="wlradar__item wlradar__item--{{urgency}} {{#completed}}wlradar__item--done{{/completed}}">
                    <a class="wlradar__item-link" href="{{url}}">
                        <span class="wlradar__chip wlradar__chip--{{urgency}}">{{countdown}}</span>
                        <span class="wlradar__item-body">
                            <span class="wlradar__item-name">{{name}}</span>
                            <span class="wlradar__item-meta">{{coursename}}</span>
                        </span>
                    </a>
                </li>
            {{/topitems}}
        </ul>

        <footer class="wlradar__footer">
            {{#hidden_when_collapsed}}
                <span class="wlradar__more">+{{hidden_when_collapsed}} {{#str}} more, block_workloadradar {{/str}}</span>
            {{/hidden_when_collapsed}}
            <a class="wlradar__cta" href="{{fullviewurl}}">
                {{#str}} viewfull, block_workloadradar {{/str}} →
            </a>
        </footer>
    {{/hasitems}}
</div>
